{
  "name": "chaosclaw",
  "version": "0.1.0",
  "description": "Deterministic CLI for Kubernetes Continuous Control Verification",
  "keywords": [
    "kubernetes",
    "security",
    "verification",
    "policy",
    "chaos"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chaosclaw/chaosclaw.git"
  },
  "type": "module",
  "bin": {
    "chaosclaw": "./dist/index.mjs"
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "^1.0.0-rc.9"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "oxlint": "^1.55.0",
    "tsdown": "0.21.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
